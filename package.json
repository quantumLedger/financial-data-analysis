{
  "name": "financial-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx dotenv -e .env.prod -- next build",
    "start": "npx dotenv -e .env.prod -- next start",
    "start:prod": "npx dotenv -e .env.prod -- next start",
    "lint": "next lint",
    "postinstall": "npx dotenv -e .env.prod -- prisma generate || true",
    "db:migrate:prod": "npx dotenv -e .env.prod -- prisma migrate deploy",
    "prod": "npm run db:migrate:prod && npm run build && npm run start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.4.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@syncfusion/ej2-base": "^31.1.22",
    "@syncfusion/ej2-excel-export": "^31.1.17",
    "@syncfusion/ej2-pdf-export": "^31.1.17",
    "@syncfusion/ej2-react-buttons": "^31.1.21",
    "@syncfusion/ej2-react-dropdowns": "^31.1.22",
    "@syncfusion/ej2-react-inputs": "^31.1.22",
    "@syncfusion/ej2-react-popups": "^31.1.20",
    "@syncfusion/ej2-react-spreadsheet": "^31.1.22",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.452.0",
    "next": "^16.1.5",
    "next-themes": "^0.3.0",
    "pdfjs-dist": "^4.7.76",
    "pg": "^8.20.0",
    "prisma": "^7.4.1",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
